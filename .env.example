# ──────────────────────────────────────────────────────────────────────────────
# TabSlate Server (OSS) — environment variables
#
# Copy to .env and fill in the required values before starting the server.
# Required fields are marked with [required].
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# [required] PostgreSQL 17+ connection string.
DATABASE_URL=postgres://user:password@localhost:5432/tabslate

# ── Auth ──────────────────────────────────────────────────────────────────────
# [required] HMAC-HS256 signing secret for access tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
# Set to "release" in production to suppress Gin debug output.
GIN_MODE=debug

# ── License (OSS self-hosted) ─────────────────────────────────────────────────
# License JWT purchased from tabslate.app/pricing.
# Leave empty to run in free-tier mode (1 workspace, 1 000 bookmarks, etc.).
# LICENSE_KEY=

# ── Prosopo CAPTCHA ───────────────────────────────────────────────────────────
# Server-side secret key for verifying captcha tokens (Server Secret Key).
# Leave empty to disable captcha verification entirely.
PROSOPO_SECRET=

# Verification endpoint. Override only for self-hosted Prosopo deployments.
# PROSOPO_SERVER_URL=https://api.prosopo.io/siteverify

# JS bundle URL served to the browser iframe widget.
# Override only for self-hosted Prosopo deployments.
# PROSOPO_BUNDLE_URL=https://js.prosopo.io/js/procaptcha.bundle.js

# ── Email ─────────────────────────────────────────────────────────────────────
# Email provider: "smtp" or "resend". Leave empty to disable email verification
# (all newly registered users are auto-verified — not recommended in production).
MAIL_PROVIDER=

# SMTP settings (used when MAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@tabslate.app

# Resend settings (used when MAIL_PROVIDER=resend)
# RESEND_API_KEY=
# RESEND_FROM=TabSlate <noreply@tabslate.app>
