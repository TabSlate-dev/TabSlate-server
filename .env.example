# Copy to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# Development (local SQLite via libsql):
DATABASE_URL=file:./dev.db
# Production — Turso:
# DATABASE_URL=libsql://your-db-name.turso.io?authToken=your-auth-token
# Production — PostgreSQL 17+:
# DATABASE_URL=postgres://user:password@localhost:5432/tabslate?sslmode=disable

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
GIN_MODE=debug   # set to "release" in production

# ── License (OSS edition) ─────────────────────────────────────────────────────
# Leave empty to run in free-tier mode.
# Set to a signed License JWT to unlock Pro/Enterprise limits.
# LICENSE_KEY=
