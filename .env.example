# ──────────────────────────────────────────────────────────────────────────────
# TabSlate Server (OSS) — environment variables
#
# Copy to .env and fill in the required values before starting the server.
# Required fields are marked with [required].
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# [required] PostgreSQL 17+ connection string.
DATABASE_URL=postgres://user:password@localhost:5432/tabslate

# [optional] Redis Cache
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# [required] HMAC-HS256 signing secret for access tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
# Set to "release" in production to suppress Gin debug output.
GIN_MODE=debug

# ── License (OSS self-hosted) ─────────────────────────────────────────────────
# License JWT purchased from tabslate.app/pricing.
# Leave empty to run in free-tier mode (1 workspace, 1 000 bookmarks, etc.).
# LICENSE_KEY=

# ── Prosopo CAPTCHA ───────────────────────────────────────────────────────────
# Server-side secret key for verifying captcha tokens (Server Secret Key).
# Leave empty to disable captcha verification entirely.
PROSOPO_SECRET=

# Verification endpoint. Override only for self-hosted Prosopo deployments.
# PROSOPO_SERVER_URL=https://api.prosopo.io/siteverify

# JS bundle URL served to the browser iframe widget.
# Override only for self-hosted Prosopo deployments.
# PROSOPO_BUNDLE_URL=https://js.prosopo.io/js/procaptcha.bundle.js

# Number of successful registrations from a single IP within the window
# before captcha is required on /auth/register. Set to 0 to always require.
# Defaults to 3.
# REGISTER_CAPTCHA_THRESHOLD=3

# Look-back window for per-IP registration counting. Any Go duration string.
# Defaults to 24h.
# REGISTER_CAPTCHA_WINDOW=24h

# Number of OTP email requests (resend / forgot-password) from a single IP
# within the window before captcha is required. Set to 0 to always require.
# Defaults to 5.
# OTP_CAPTCHA_THRESHOLD=5

# Look-back window for per-IP OTP request counting. Any Go duration string.
# Defaults to 15m.
# OTP_CAPTCHA_WINDOW=15m

# ── Email ─────────────────────────────────────────────────────────────────────
# Email provider: "smtp" or "resend". Leave empty to disable email verification
# (all newly registered users are auto-verified — not recommended in production).
MAIL_PROVIDER=

# SMTP settings (used when MAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@tabslate.app

# Resend settings (used when MAIL_PROVIDER=resend)
# RESEND_API_KEY=
# RESEND_FROM=TabSlate <noreply@tabslate.app>

# ── MeiliSearch (full-text bookmark search) ───────────────────────────────────
# Internal URL of the MeiliSearch instance. Leave empty to disable search indexing.
# Example for Docker Compose: http://meilisearch:7700
# MEILISEARCH_HOST=http://localhost:7700

# Master or admin API key configured in MeiliSearch (MEILI_MASTER_KEY).
# MEILISEARCH_API_KEY=masterKey

# ── Rate limiters ─────────────────────────────────────────────────────────────
# Per-IP request caps for each endpoint group. Windows accept any Go duration
# string (e.g. "30s", "1m", "5m"). Defaults shown below.

# Auth endpoints (register, login, resend-verification, verify-email, OTP):
# RATE_LIMIT_AUTH=10
# RATE_LIMIT_AUTH_WINDOW=1m

# Sync push (POST /sync/push):
# RATE_LIMIT_SYNC_PUSH=60
# RATE_LIMIT_SYNC_PUSH_WINDOW=1m

# Sync pull (GET /sync/pull):
# RATE_LIMIT_SYNC_PULL=120
# RATE_LIMIT_SYNC_PULL_WINDOW=1m

# Bookmark search (GET /search):
# RATE_LIMIT_SEARCH=60
# RATE_LIMIT_SEARCH_WINDOW=1m
