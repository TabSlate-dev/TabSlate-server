# Copy to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL 17+ (required):
DATABASE_URL=postgres://user:password@localhost:5432/tabslate?sslmode=disable

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
GIN_MODE=debug   # set to "release" in production

# ── License (OSS edition) ─────────────────────────────────────────────────────
# Leave empty to run in free-tier mode.
# Set to a signed License JWT to unlock Pro/Enterprise limits.
# LICENSE_KEY=

# ── Prosopo Captcha ───────────────────────────────────────────────────────────
# Leave empty to disable captcha verification entirely.
# Obtain from https://prosopo.io
# PROSOPO_SECRET=your-prosopo-site-secret
#
# Override for self-hosted Prosopo deployments (default: https://api.prosopo.io/siteverify):
# PROSOPO_SERVER_URL=https://your-prosopo-server.example.com/siteverify

# ── Email Verification ───────────────────────────────────────────────────────
# Provider: "smtp" or "resend". Leave empty to disable email verification
# (users will be auto-verified on registration).
# MAIL_PROVIDER=smtp

# SMTP settings (when MAIL_PROVIDER=smtp):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-username
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@tabslate.app

# Resend settings (when MAIL_PROVIDER=resend):
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=TabSlate <noreply@tabslate.app>

# Base URL for verification links (e.g. https://api.tabslate.app):
# VERIFY_BASE_URL=http://localhost:8080
